# =============================================================================
# Carteira IRPF — backend (FastAPI)
# Copia para .env e ajusta. Não commits o .env com segredos.
# =============================================================================

# SQLite principal (por omissão: backend/data/irpf_carteira.db)
# Windows: usa barras normais ou duplica barras invertidas no URL.
# DATABASE_URL=sqlite:///C:/caminho/completo/irpf_carteira.db

# Origens CORS (separadas por vírgula). Deve incluir o URL onde abres o frontend.
# Dev Vite: 5173 | Preview do build: 4173
# CORS_ORIGINS=http://localhost:4173,http://127.0.0.1:4173,http://localhost:5173,http://127.0.0.1:5173

# -----------------------------------------------------------------------------
# Nota: integrações (Asaas, Serpro, certificado A1, pasta GovBox) ficam na
# tabela app_kv da base SQLite — ver CONFIGURACAO.md na raiz do projeto.
# -----------------------------------------------------------------------------
